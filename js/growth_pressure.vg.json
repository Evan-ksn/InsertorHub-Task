{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Clean two-panel stakeholder view with no overlapping labels.",
  "width": "container",
  "height": 400,
  "data": {
    "values": [
      {
        "Metric": "CAC efficiency",
        "Type": "Improved",
        "Value": "$33",
        "Move": "↓ 56%",
        "Detail": "Customer acquisition became materially cheaper",
        "Score": 96,
        "Rank": 1
      },
      {
        "Metric": "Marketing efficiency",
        "Type": "Improved",
        "Value": "$9.6M",
        "Move": "↓ 30%",
        "Detail": "Marketing and advertising costs reduced",
        "Score": 88,
        "Rank": 2
      },
      {
        "Metric": "New customers",
        "Type": "Improved",
        "Value": "221.7K",
        "Move": "↑ 22%",
        "Detail": "New customer growth accelerated",
        "Score": 78,
        "Rank": 3
      },
      {
        "Metric": "Underlying EBITDA",
        "Type": "Improved",
        "Value": "$4.1M",
        "Move": "↑ 15%",
        "Detail": "Underlying EBITDA improved despite investment",
        "Score": 67,
        "Rank": 4
      },
      {
        "Metric": "Revenue",
        "Type": "Improved",
        "Value": "$111.9M",
        "Move": "↑ 9%",
        "Detail": "Topline growth remains positive",
        "Score": 58,
        "Rank": 5
      },
      {
        "Metric": "Gross margin",
        "Type": "Watch",
        "Value": "35.0%",
        "Move": "↓ 120 bps",
        "Detail": "Promotional activity supported sales but pressured margin",
        "Score": 92,
        "Rank": 1
      },
      {
        "Metric": "Inventory",
        "Type": "Watch",
        "Value": "$27.9M",
        "Move": "was $20.3M",
        "Detail": "Inventory increased as the store network scales",
        "Score": 82,
        "Rank": 2
      },
      {
        "Metric": "Cash",
        "Type": "Watch",
        "Value": "$8.2M",
        "Move": "was $12.7M",
        "Detail": "Cash reduced while the business invests in growth",
        "Score": 74,
        "Rank": 3
      },
      {
        "Metric": "Employee costs",
        "Type": "Watch",
        "Value": "$14.8M",
        "Move": "↑ 28%",
        "Detail": "Cost growth needs to convert into operating leverage",
        "Score": 63,
        "Rank": 4
      },
      {
        "Metric": "Other costs",
        "Type": "Watch",
        "Value": "$10.7M",
        "Move": "↑ 27%",
        "Detail": "Other operating costs rose as the business scales",
        "Score": 58,
        "Rank": 5
      }
    ]
  },
  "transform": [
    {
      "calculate": "datum.Value + ' · ' + datum.Move",
      "as": "Label"
    },
    {
      "calculate": "datum.Value + ' · ' + datum.Move + ' — ' + datum.Detail",
      "as": "TooltipText"
    }
  ],
  "facet": {
    "column": {
      "field": "Type",
      "type": "nominal",
      "sort": [
        "Improved",
        "Watch"
      ],
      "header": {
        "title": null,
        "labelExpr": "datum.label == 'Improved' ? 'Strengthening the story' : 'Needs watching'",
        "labelFontSize": 24,
        "labelFontWeight": "bold",
        "labelColor": "#2A1221",
        "labelPadding": 22
      }
    }
  },
  "spec": {
    "width": 540,
    "height": 295,
    "layer": [
      {
        "mark": {
          "type": "bar",
          "cornerRadius": 16,
          "height": {
            "band": 0.62
          },
          "color": "#F5ECE8"
        },
        "encoding": {
          "x": {
            "datum": 100,
            "type": "quantitative",
            "scale": {
              "domain": [
                0,
                155
              ]
            },
            "axis": null
          },
          "y": {
            "field": "Metric",
            "type": "nominal",
            "sort": {
              "field": "Rank",
              "order": "ascending"
            },
            "axis": {
              "title": null,
              "domain": false,
              "ticks": false,
              "labelColor": "#4E3340",
              "labelFontSize": 15,
              "labelLimit": 190,
              "labelPadding": 10
            }
          }
        }
      },
      {
        "mark": {
          "type": "bar",
          "cornerRadius": 16,
          "height": {
            "band": 0.62
          }
        },
        "encoding": {
          "x": {
            "field": "Score",
            "type": "quantitative",
            "scale": {
              "domain": [
                0,
                155
              ]
            },
            "axis": null
          },
          "y": {
            "field": "Metric",
            "type": "nominal",
            "sort": {
              "field": "Rank",
              "order": "ascending"
            }
          },
          "color": {
            "field": "Type",
            "type": "nominal",
            "scale": {
              "domain": [
                "Improved",
                "Watch"
              ],
              "range": [
                "#B76782",
                "#4B1832"
              ]
            },
            "legend": null
          },
          "tooltip": [
            {
              "field": "Metric",
              "title": "Metric"
            },
            {
              "field": "Type",
              "title": "Signal"
            },
            {
              "field": "Label",
              "title": "Reported result"
            },
            {
              "field": "Detail",
              "title": "Why it matters"
            }
          ]
        }
      },
      {
        "mark": {
          "type": "text",
          "align": "left",
          "baseline": "middle",
          "dx": 12,
          "fontSize": 14,
          "fontWeight": "bold",
          "color": "#2A1221"
        },
        "encoding": {
          "x": {
            "datum": 104,
            "type": "quantitative",
            "scale": {
              "domain": [
                0,
                155
              ]
            }
          },
          "y": {
            "field": "Metric",
            "type": "nominal",
            "sort": {
              "field": "Rank",
              "order": "ascending"
            }
          },
          "text": {
            "field": "Label"
          }
        }
      }
    ]
  },
  "resolve": {
    "scale": {
      "x": "independent",
      "y": "independent",
      "color": "shared"
    }
  },
  "config": {
    "background": "transparent",
    "view": {
      "stroke": null
    },
    "facet": {
      "spacing": 24
    },
    "axis": {
      "grid": false,
      "domain": false,
      "labelFont": "Inter, ui-sans-serif, system-ui, -apple-system, Segoe UI, sans-serif",
      "titleFont": "Inter, ui-sans-serif, system-ui, -apple-system, Segoe UI, sans-serif"
    },
    "header": {
      "labelFont": "Inter, ui-sans-serif, system-ui, -apple-system, Segoe UI, sans-serif"
    }
  }
}